# Hugo build output
public/
resources/_gen/

# Hugo cache
.hugo_build.lock

# OS generated files
.DS_Store
._*
Thumbs.db

# Editor files
*.swp
*.swo
*~
.idea/
.vscode/

# Environment files (should never exist in this repo, but just in case)
.env
.env.*
!.env.example

# Node modules (if using npm for any tooling)
node_modules/

# Temporary files
*.tmp
*.temp
*.log

# Private notes (local only, never committed)
.private/
_drafts-private/
nanobanana-output/

# Archived assets (local backup only)
.archive/

# Local nested repos / removed submodules (prevent auto-sync from re-adding)
panos-pytest-baseline/
themes/PaperMod/

# Claude Code local settings (per-machine by design — see Anthropic docs)
.claude/settings.local.json

# OMC runtime state (sessions, artifacts, plans, checkpoints — regenerable per machine)
.omc/

# Playwright MCP DOM snapshots (debugging residue, regenerable)
.playwright-mcp/

# Operator-only planning notes (kept in private homelab-infra repo)
_planning/

# OS metadata and editor swap files
.AppleDouble/
.LSOverride
Icon?
.Spotlight-V100/
.Trashes/
.fseventsd/
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.nfs*
